# Database (Supabase) — find these in the "Connect" dialog on your project dashboard
# `uselibpqcompat=true&sslmode=require` = encrypt without full chain verification.
# `sslmode=verify-full` fails against Supabase's pooler ("self-signed certificate in
# certificate chain") without also supplying Supabase's CA bundle, so this is used instead.
# DATABASE_URL: "Transaction pooler" (port 6543) — used by the app at runtime
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&uselibpqcompat=true&sslmode=require"
# DIRECT_URL: "Session pooler" (port 5432) — used for migrations.
# NOTE: the true "Direct connection" host (db.<ref>.supabase.co) is IPv6-only and
# unreachable from many networks/CI — the session pooler is IPv4-compatible and still
# supports the stable per-connection semantics migrations need.
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxx:password@aws-0-region.pooler.supabase.com:5432/postgres?uselibpqcompat=true&sslmode=require"

# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL="/"

# Clerk webhook (Dashboard > Webhooks > Signing Secret)
CLERK_WEBHOOK_SIGNING_SECRET="whsec_..."

# Web Push — generate your own with `npx web-push generate-vapid-keys`
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"

# Any random string — protects /api/cron/check-notifications from public triggering
CRON_SECRET=""
